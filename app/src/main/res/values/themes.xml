<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.StokIkanGiling" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="materialCardViewStyle">@style/Widget.StokIkanGiling.Card</item>
        <item name="materialButtonStyle">@style/Widget.StokIkanGiling.Button</item>
        <item name="textInputStyle">@style/Widget.StokIkanGiling.TextInputLayout</item>
    </style>

    <style name="Widget.StokIkanGiling.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.StokIkanGiling.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">54dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="iconTint">@android:color/white</item>
    </style>

    <style name="Widget.StokIkanGiling.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">54dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/stroke_strong</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="iconTint">@color/primary_dark</item>
    </style>

    <style name="Widget.StokIkanGiling.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.StokIkanGiling.Heading" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.StokIkanGiling.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>
