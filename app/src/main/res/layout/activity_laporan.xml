<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarLaporan"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:title="Laporan Stok"
        android:titleTextColor="@android:color/white"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationIconTint="@android:color/white" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/page_margin">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_soft_panel"
                android:orientation="vertical"
                android:padding="18dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_section_chip" android:text="Laporan Ringkas" android:textColor="@color/primary_dark" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:autoSizeMaxTextSize="23sp" android:autoSizeMinTextSize="17sp" android:autoSizeStepGranularity="1sp" android:autoSizeTextType="uniform" android:maxLines="2" android:text="Ringkasan Stok dan Riwayat" android:textColor="@color/text_primary" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Data laporan disusun dari produk, stok aktif, histori transaksi, dan catatan pendukung yang tersimpan secara lokal." android:textColor="@color/text_secondary" android:textSize="14sp" android:lineSpacingExtra="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_soft_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Aksi Data Laporan" android:textColor="@color/text_primary" android:textSize="17sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Export data ke CSV agar bisa dibuka di Excel, atau import catatan pemeriksaan dari file TXT/CSV." android:textColor="@color/text_secondary" android:textSize="13sp" android:lineSpacingExtra="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExportCsv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Export CSV untuk Excel"
                    android:textSize="14sp"
                    app:icon="@android:drawable/stat_sys_download"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnImportCatatan"
                    style="@style/Widget.StokIkanGiling.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Import Catatan Laporan"
                    android:textSize="14sp"
                    app:icon="@android:drawable/ic_menu_upload"
                    app:iconGravity="textStart" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Total Produk" android:textColor="@color/text_secondary" android:textSize="13sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvLaporanProduk" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:autoSizeMaxTextSize="30sp" android:autoSizeMinTextSize="18sp" android:autoSizeStepGranularity="1sp" android:autoSizeTextType="uniform" android:maxLines="1" android:text="0" android:textColor="@color/text_primary" android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Total Stok" android:textColor="@color/text_secondary" android:textSize="13sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvLaporanTotalStok" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:autoSizeMaxTextSize="28sp" android:autoSizeMinTextSize="16sp" android:autoSizeStepGranularity="1sp" android:autoSizeTextType="uniform" android:maxLines="1" android:text="0 kg" android:textColor="@color/text_primary" android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Nilai Persediaan" android:textColor="@color/text_secondary" android:textSize="13sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvLaporanNilai" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:autoSizeMaxTextSize="27sp" android:autoSizeMinTextSize="15sp" android:autoSizeStepGranularity="1sp" android:autoSizeTextType="uniform" android:maxLines="2" android:text="Rp0" android:textColor="@color/text_primary" android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" app:cardElevation="3dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Stok Rendah" android:textColor="@color/text_secondary" android:textSize="13sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvLaporanStokRendah" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:autoSizeMaxTextSize="30sp" android:autoSizeMinTextSize="18sp" android:autoSizeStepGranularity="1sp" android:autoSizeTextType="uniform" android:maxLines="1" android:text="0" android:textColor="@color/warning" android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutCatatanImport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_empty_state"
                android:orientation="vertical"
                android:padding="18dp"
                android:visibility="gone">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Catatan Import" android:textColor="@color/text_primary" android:textSize="17sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvCatatanImportInfo" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Sumber file" android:textColor="@color/text_muted" android:textSize="12sp" />
                <TextView android:id="@+id/tvCatatanImportIsi" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:textColor="@color/text_secondary" android:textSize="13sp" android:lineSpacingExtra="3dp" />
            </LinearLayout>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="26dp" android:text="Riwayat Perubahan Stok" android:textColor="@color/text_primary" android:textSize="19sp" android:textStyle="bold" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Setiap stok masuk dan stok keluar dicatat sebagai histori aktivitas lokal." android:textColor="@color/text_secondary" android:textSize="13sp" />

            <LinearLayout android:id="@+id/layoutRiwayatKosong" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="@drawable/bg_empty_state" android:gravity="center" android:orientation="vertical" android:padding="26dp" android:visibility="gone">
                <TextView android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/bg_stat_icon_primary" android:gravity="center" android:text="≡" android:textColor="@color/primary_dark" android:textSize="26sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="Belum ada riwayat stok" android:textColor="@color/text_primary" android:textSize="17sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:gravity="center" android:text="Riwayat akan muncul setelah stok masuk atau stok keluar dicatat." android:textColor="@color/text_secondary" android:textSize="14sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRiwayatStok"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="22dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
